{
  "name": "@bitshard.io/bitshard-wagmi-connector",
  "version": "0.1.0",
  "description": "Wagmi connector for the BitShard MPC wallet. Lets dApps connect to a non-custodial 2-of-3 threshold wallet via a hosted popup, with no per-dApp browser extension.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wagmi",
    "connector",
    "wallet",
    "mpc",
    "threshold-signatures",
    "dkls",
    "dkls23",
    "bitshard",
    "arbitrum",
    "ethereum",
    "web3"
  ],
  "author": "bitshard.io",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitshard-io/bitshard-wagmi-connector"
  },
  "homepage": "https://bitshard.io",
  "bugs": {
    "url": "https://github.com/bitshard-io/bitshard-wagmi-connector/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@wagmi/core": "^2.0.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@wagmi/core": "^2.13.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "viem": "^2.21.0"
  },
  "engines": {
    "node": ">=18"
  }
}
